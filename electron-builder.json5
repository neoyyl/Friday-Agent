// @see - https://www.electron.build/configuration/configuration
// 构建配置统一入口 (package.json 中的 build 段已废弃，以此文件为准)
{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.friday.agent",
  "asar": true,
  "asarUnpack": [
    "node_modules/better-sqlite3/**/*"
  ],
  "productName": "Friday Agent",
  "copyright": "Copyright © 2026",
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist",
    "dist-electron"
  ],
  "mac": {
    "target": [
      "dmg"
    ],
    "artifactName": "${productName}-Mac-${version}-Installer.${ext}",
    "icon": "public/Friday.ico"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "${productName}-Windows-${version}-Setup.${ext}",
    "signAndEditExecutable": false,
    "icon": "public/Friday.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Friday Agent",
    "deleteAppDataOnUninstall": false,
    "installerIcon": "public/Friday.ico",
    "uninstallerIcon": "public/Friday.ico",
    "installerHeaderIcon": "public/Friday.ico"
  },
  "linux": {
    "target": [
      "AppImage"
    ],
    "artifactName": "${productName}-Linux-${version}.${ext}",
    "icon": "public/Friday.ico"
  },
  "publish": {
    "provider": "github",
    "owner": "friday-team",
    "repo": "friday-agent",
    "releaseType": "release",
    "publishAutoUpdate": true
  }
}
